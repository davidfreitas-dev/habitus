{
  "name": "habitus",
  "private": true,
  "version": "0.0.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "cypress run",
    "test:unit": "vitest",
    "lint": "eslint",
    "setup:ios": "npm run build && npx cap add ios && npx cap sync ios && npx cap open ios",
    "live:ios": "ionic capacitor run ios -l --external",
    "live:android": "ionic capacitor run android -l --external",
    "prod:android": "ionic build --prod && npx cap sync android && npx cap open android",
    "prod:ios": "ionic build --prod && npx cap sync ios && npx cap open ios",
    "android:setup": "node scripts/patch-android-manifest.js && npm run assets:generate",
    "assets:generate": "cp assets/ic_stat_habitus.png android/app/src/main/res/drawable/ic_stat_habitus.png && npx capacitor-assets generate"
  },
  "dependencies": {
    "@capacitor/android": "8.1.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/local-notifications": "^8.0.1",
    "@capacitor/network": "^8.0.1",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@ionic/vue": "8.7.17",
    "@ionic/vue-router": "8.7.17",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "axios": "^1.2.1",
    "chart.js": "^4.5.1",
    "dayjs": "^1.11.10",
    "ionicons": "^7.0.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.28",
    "vue-axios": "^3.5.2",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.1.6"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.0.0",
    "@eslint/js": "^9.39.2",
    "@vitejs/plugin-legacy": "^7.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.3.0",
    "cypress": "^13.17.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^22.1.0",
    "terser": "^5.24.0",
    "vite": "^7.0.0",
    "vitest": "^2.1.9"
  },
  "description": "Habitus - A modern and intuitive habit tracker built with Ionic, Vue, and Capacitor."
}
